# Copy this to .env for local testing
# On Railway, set these in the Variables tab — never commit real keys to GitHub

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Set to false when you're ready to go live
DRY_RUN=true

# Leverage (start at 3-5x)
LEVERAGE=5

# Optional: Telegram alerts on your iPhone
# 1. Create a bot via @BotFather → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → copy your chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
